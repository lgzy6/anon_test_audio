__pycache__/
*.pyc
*.pyo
*.pyd
*.so
*.egg-info/
build/
dist/

############################################
# 2. 虚拟环境
############################################
env/
venv/
.venv/
conda/
*.conda

############################################
# 3. 日志文件
############################################
logs/
*.log

############################################
# 4. 训练输出与实验结果
############################################
outputs/
data/samm_anon/logs/

############################################
# 5. 模型权重（非常关键）
############################################
*.pt
*.pth
*.ckpt

checkpoints/
outputs/*/*.pt
outputs/*/*/*.pt

############################################
# 6. 目标池 / 向量索引 / 特征缓存
############################################
*.npy
*.npz
*.index
*.h5

data/samm_anon/target_pool_*/
cache/
checkpoints/target_pool/

############################################
# 7. 音频文件（默认不提交）
############################################
*.wav
*.flac
*.mp3

############################################
# 8. 可视化图片（实验产物）
############################################
*.png
*.jpg
*.jpeg

############################################
# 9. 临时脚本 / Shell 产物
############################################
*.sh~
*.swp

############################################
# 10. 系统文件
############################################
.DS_Store
Thumbs.db.claude/
